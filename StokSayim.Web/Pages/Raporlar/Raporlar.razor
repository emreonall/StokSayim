@page "/raporlar"
@page "/raporlar/{PlanId:int}"
@attribute [Authorize(Roles = "Admin,SayimSorumlusu")]
@inject ISayimPlaniHttpService PlanService
@inject IRaporHttpService RaporService
@inject IErpKontrolHttpService ErpKontrolService
@inject IEkipHttpService EkipService
@inject NavigationManager Nav

<PageTitle>Raporlar</PageTitle>

<div class="ss-page-header">
    <div>
        <h1 class="ss-page-title">Raporlar</h1>
        <p class="ss-page-subtitle">Sayım durum ve fark raporları</p>
    </div>
</div>

<div class="ss-card" style="margin-bottom:16px">
    <div style="display:flex; gap:16px; align-items:flex-end; flex-wrap:wrap">
        <div class="ss-form-group" style="flex:1; min-width:200px; margin-bottom:0">
            <label>Plan Seç</label>
            <SfDropDownList DataSource="@_planlar" @bind-Value="_secilenPlanId"
                            TValue="int" TItem="SayimPlaniListDto"
                            Placeholder="Rapor için plan seçin...">
                <DropDownListFieldSettings Value="Id" Text="PlanAdi"></DropDownListFieldSettings>
                <DropDownListEvents TValue="int" TItem="SayimPlaniListDto"
                                    ValueChange="@(async e => { _secilenPlanId = (int)(e.Value); await YukleRaporlar(); })">
                </DropDownListEvents>
            </SfDropDownList>
        </div>
        @if (_secilenPlanId > 0)
        {
        }
    </div>
</div>

@if (_secilenPlanId == 0)
{
    <div class="ss-empty"><div class="ss-empty-icon">📊</div><div class="ss-empty-text">Plan seçin</div></div>
}
else if (_raporYukleniyor)
{
    <div class="ss-loading"><SfSpinner Visible="true" /> Rapor hazırlanıyor...</div>
}
else
{
    @if (_durumRaporu != null)
    {
        <!-- İstatistikler -->
        <div class="ss-stats">
            <div class="ss-stat primary">
                <div class="ss-stat-label">Toplam Bölge</div>
                <div class="ss-stat-value">@_durumRaporu.ToplamBolge</div>
            </div>
            <div class="ss-stat success">
                <div class="ss-stat-label">Tamamlanan</div>
                <div class="ss-stat-value">@_durumRaporu.TamamlananBolge</div>
            </div>
            <div class="ss-stat">
                <div class="ss-stat-label">Devam Eden</div>
                <div class="ss-stat-value">@_durumRaporu.DevamEdenBolge</div>
            </div>
            <div class="ss-stat warn">
                <div class="ss-stat-label">Bekleyen</div>
                <div class="ss-stat-value">@_durumRaporu.BekleyenBolge</div>
            </div>
        </div>

        <!-- Bölge Durumları -->
        <div class="ss-card">
            <div class="ss-card-title">Bölge Bazında Sayım Durumu</div>
            <SfGrid DataSource="@_durumRaporu.BolgeDurumlari" AllowPaging="true" AllowSorting="true">
                <GridPageSettings PageSize="15" />
                <GridColumns>
                    <GridColumn Field="BolgeKodu" HeaderText="Kod" Width="100" />
                    <GridColumn Field="BolgeAdi" HeaderText="Bölge Adı" Width="200" />
                    <GridColumn Field="OturumDurum" HeaderText="Durum" Width="140">
                        <Template>
                            @{
                                var b = (BolgeDurumDto)context;
                                var (cls, txt) = b.OturumDurum switch
                                {
                                    "Onaylandi" or "ManuelKarar" => ("ss-badge-success", b.OturumDurum),
                                    "DevamEdiyor" => ("ss-badge-accent", "Devam Ediyor"),
                                    _ => ("ss-badge-muted", "Başlamadı")
                                };
                            }
                            <span class="ss-badge @cls">@txt</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Tur İlerleme" Width="160" TextAlign="TextAlign.Center">
                        <Template>
                            @{
                                var b = (BolgeDurumDto)context;
                                var pct = b.ToplamTurSayisi == 0 ? 0 : (int)((double)b.TamamlananTurSayisi / b.ToplamTurSayisi * 100);
                            }
                            <span>@b.TamamlananTurSayisi/@b.ToplamTurSayisi tur (%@pct)</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="ErpKarsilastirmaYapildiMi" HeaderText="ERP Karş." Width="110" TextAlign="TextAlign.Center">
                        <Template>
                            @{
                                var b = (BolgeDurumDto)context;
                            }
                            <span>@(b.ErpKarsilastirmaYapildiMi ? "✅" : "—")</span>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        </div>

        <!-- Ekip Sayım Özeti -->
        @if (_durumRaporu.EkipSayimOzetleri.Any())
        {
            <div class="ss-card">
                <div class="ss-card-title">Ekip Bazında Sayım Özeti</div>
                <SfGrid DataSource="@_durumRaporu.EkipSayimOzetleri" AllowSorting="true">
                    <GridColumns>
                        <GridColumn Field="EkipAdi" HeaderText="Ekip" Width="200" />
                        <GridColumn Field="TamamlananSayimSayisi" HeaderText="Tamamlanan" Width="130" TextAlign="TextAlign.Center" />
                        <GridColumn Field="ToplamSayimSayisi" HeaderText="Toplam" Width="100" TextAlign="TextAlign.Center" />
                    </GridColumns>
                </SfGrid>
            </div>
        }
    }

    @if (_farkRaporu != null)
    {
        <!-- Sayım Sonuç Raporu -->
        <div class="ss-card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px">
                <div>
                    <div class="ss-card-title" style="margin-bottom:4px">Sayım Sonuç Raporu</div>
                    @if (_farkRaporu.FarkliSatir > 0)
                    {
                        <div style="font-size:12px; color:var(--muted)">
                            Fark olan satırlarda ekip atayarak ERP kontrol sayımı başlatabilirsiniz.
                        </div>
                    }
                </div>
                <div style="display:flex; gap:8px; align-items:center">
                    @if (_erpKontrolOturumu != null)
                    {
                        <span class="ss-badge @(_erpKontrolOturumu.Durum == ErpKontrolOturumuDurum.Tamamlandi ? "ss-badge-success" : "ss-badge-warn")">
                            ERP Kontrol: @_erpKontrolOturumu.Durum
                        </span>
                    }
                    @if (_malzemeEkipAtamalari.Any(kv => kv.Value > 0))
                    {
                        <SfButton CssClass="e-primary" @onclick="ErpKontrolKaydet">
                            ✅ ERP Kontrol Sayımını Başlat (@_malzemeEkipAtamalari.Count(kv => kv.Value > 0) malzeme)
                        </SfButton>
                    }
                </div>
            </div>

            <div class="ss-stats" style="margin-bottom:16px">
                <div class="ss-stat">
                    <div class="ss-stat-label">Toplam Satır</div>
                    <div class="ss-stat-value">@_farkRaporu.ToplamSatir.ToString("N0")</div>
                </div>
                <div class="ss-stat success">
                    <div class="ss-stat-label">Farksız</div>
                    <div class="ss-stat-value">@_farkRaporu.FarksizSatir.ToString("N0")</div>
                </div>
                <div class="ss-stat danger">
                    <div class="ss-stat-label">Farklı</div>
                    <div class="ss-stat-value">@_farkRaporu.FarkliSatir.ToString("N0")</div>
                </div>
            </div>

            <SfGrid ID="farkRaporGrid" @ref="_farkGrid" DataSource="@_farkRaporu.FarkDetaylari"
                    AllowPaging="true" AllowSorting="true" AllowFiltering="true"
                    AllowExcelExport="true" Toolbar="@(new List<string>() { "ExcelExport", "CsvExport" })">
                <GridEvents OnToolbarClick="ToolbarClickHandler" TValue="FarkDetayDto" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.FilterBar" />
                <GridPageSettings PageSize="20" />
                <GridColumns>
                    <GridColumn Field="MalzemeKodu" HeaderText="Malzeme Kodu" Width="130" />
                    <GridColumn Field="MalzemeAdi" HeaderText="Malzeme Adı" Width="200" />
                    <GridColumn Field="Birim" HeaderText="Birim" Width="80" TextAlign="TextAlign.Center" />
                    <GridColumn Field="ErpMiktar" HeaderText="ERP Stok" Format="N2" Width="110" TextAlign="TextAlign.Right">
                        <Template>
                            @{
                                var f = (FarkDetayDto)context;
                            }
                            <span style="@(f.ErpMiktar == 0 ? "color:var(--muted)" : "")">
                                @(f.ErpMiktar == 0 ? "—" : f.ErpMiktar.ToString("N2"))
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="FiiliMiktar" HeaderText="Sayım" Format="N2" Width="110" TextAlign="TextAlign.Right">
                        <Template>
                            @{
                                var f = (FarkDetayDto)context;
                            }
                            <span style="@(f.FiiliMiktar == 0 ? "color:var(--muted)" : "")">
                                @(f.FiiliMiktar == 0 ? "—" : f.FiiliMiktar.ToString("N2"))
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="Fark" HeaderText="Fark" Width="100" TextAlign="TextAlign.Right">
                        <Template>
                            @{
                                var f = (FarkDetayDto)context;
                            }
                            @if (f.Fark == 0)
                            {
                                <span style="color:var(--success); font-weight:600">✓ 0</span>
                            }
                            else
                            {
                                <span style="color:@(f.Fark > 0 ? "var(--success)" : "var(--danger)"); font-weight:600">
                                    @f.Fark.ToString("N2")
                                </span>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="FarkYuzdesi" HeaderText="Fark %" Format="N1" Width="90" TextAlign="TextAlign.Right" />
                    <GridColumn Field="KararAdi" HeaderText="Karar" Width="110">
                        <Template>
                            @{
                                var f = (FarkDetayDto)context;
                            }
                            @if (f.KararTipi == KararTipi.Manuel)
                            {
                                <span class="ss-badge ss-badge-warn" title="@f.ManuelKararGerekce">⚖️ Manuel</span>
                            }
                            else if (f.Fark == 0)
                            {
                                <span class="ss-badge ss-badge-success">Eşleşti</span>
                            }
                            else
                            {
                                <span class="ss-badge ss-badge-danger">Fark Var</span>
                            }
                        </Template>
                    </GridColumn>
                    @if (_farkRaporu.FarkliSatir > 0 && _erpKontrolOturumu?.Durum != ErpKontrolOturumuDurum.Tamamlandi)
                    {
                        <GridColumn HeaderText="Kontrol Ekibi" Width="180" AllowFiltering="false" AllowSorting="false">
                            <Template>
                                @{
                                    var f = (FarkDetayDto)context;
                                }
                                @if (f.Fark != 0)
                                {
                                    <SfDropDownList DataSource="@_tumEkipler"
                                                    Value="@(_malzemeEkipAtamalari.GetValueOrDefault(f.MalzemeKodu, 0))"
                                                    ValueChanged="@((int v) => _malzemeEkipAtamalari[f.MalzemeKodu] = v)"
                                                    TValue="int" TItem="EkipDto"
                                                    Placeholder="Ekip seç...">
                                        <DropDownListFieldSettings Value="Id" Text="EkipAdi" />
                                    </SfDropDownList>
                                }
                            </Template>
                        </GridColumn>
                    }
                </GridColumns>
            </SfGrid>
        </div>
    }
}

@if (!string.IsNullOrEmpty(_mesaj))
{
    <div class="ss-alert @(_hata ? "ss-alert-danger" : "ss-alert-success")" style="margin-top:12px">@_mesaj</div>
}

@code {
    [Parameter] public int PlanId { get; set; }

    private SfGrid<FarkDetayDto>? _farkGrid;
    private IEnumerable<SayimPlaniListDto> _planlar = [];
    private int _secilenPlanId;
    private bool _raporYukleniyor = false;
    private SayimDurumRaporDto? _durumRaporu;
    private KesinFarkRaporDto? _farkRaporu;
    private ErpKontrolOturumuDto? _erpKontrolOturumu;
    private IEnumerable<EkipDto> _tumEkipler = [];
    private Dictionary<string, int> _malzemeEkipAtamalari = new();
    private string _mesaj = "";
    private bool _hata = false;

    protected override async Task OnInitializedAsync()
    {
        _planlar = await PlanService.GetAllAsync();
        if (PlanId > 0)
        {
            _secilenPlanId = PlanId;
            await YukleRaporlar();
        }
    }

    private async Task YukleRaporlar()
    {
        if (_secilenPlanId == 0) return;
        _raporYukleniyor = true;
        try
        {
            _durumRaporu = await RaporService.GetDurumRaporuAsync(_secilenPlanId);
            _farkRaporu = await RaporService.GetKesinFarkRaporuAsync(_secilenPlanId);
            _erpKontrolOturumu = await ErpKontrolService.GetOturumuAsync(_secilenPlanId);
            _tumEkipler = await EkipService.GetAllAsync();

            // Mevcut atamalar varsa grid'e yansıt
            _malzemeEkipAtamalari = new();
            if (_erpKontrolOturumu != null)
            {
                var atamalistesi = await ErpKontrolService.GetAtamaListesiAsync(_secilenPlanId);
                foreach (var a in atamalistesi.Where(a => a.AtananEkipId.HasValue))
                    _malzemeEkipAtamalari[a.MalzemeKodu] = a.AtananEkipId!.Value;
            }
        }
        catch { }
        _raporYukleniyor = false;
    }

    private async Task ToolbarClickHandler(ClickEventArgs args)
    {
        if (args.Item.Id == "farkRaporGrid_excelexport")
            await _farkGrid!.ExportToExcelAsync(new ExcelExportProperties
            {
                FileName = $"SayimSonucRaporu_{_secilenPlanId}_{DateTime.Now:yyyyMMdd}.xlsx",
                IncludeTemplateColumn = true
            });
        else if (args.Item.Id == "farkRaporGrid_csvexport")
            await _farkGrid!.ExportToCsvAsync(new ExcelExportProperties
            {
                FileName = $"SayimSonucRaporu_{_secilenPlanId}_{DateTime.Now:yyyyMMdd}.csv",
                IncludeTemplateColumn = true
            });
    }

    private async Task ErpKontrolKaydet()
    {
        var ekipAtamalari = _malzemeEkipAtamalari
            .Where(kv => kv.Value > 0)
            .GroupBy(kv => kv.Value)
            .Select(g => new ErpKontrolEkipAtamaDto(g.Key, g.Select(kv => kv.Key)))
            .ToList();

        if (!ekipAtamalari.Any())
        {
            _mesaj = "En az bir malzemeye ekip ataması yapılmalıdır."; _hata = true;
            return;
        }

        try
        {
            var request = new ErpKontrolBaslatDto(ekipAtamalari);
            _erpKontrolOturumu = await ErpKontrolService.BaslatAsync(_secilenPlanId, request);
            _mesaj = $"ERP kontrol sayımı başlatıldı. {ekipAtamalari.Sum(e => e.MalzemeKodlari.Count())} malzeme atandı.";
            _hata = false;
        }
        catch (Exception ex) { _mesaj = ex.Message; _hata = true; }
    }
}
