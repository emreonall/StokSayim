@page "/tur-sonucu/{TurId:int}"
@attribute [Authorize(Roles = "Admin,SayimSorumlusu")]
@inject ISayimOturumuHttpService OturumuService
@inject ToastService Toast
@inject NavigationManager Nav
@inject IJSRuntime JS
@using Syncfusion.Blazor.Grids

<PageTitle>Tur Sonucu</PageTitle>

@if (_yukleniyor)
{
    <div class="ss-loading"><SfSpinner Visible="true" /> Yükleniyor...</div>
}
else
{
    <div class="ss-page-header">
        <div>
            <h1 class="ss-page-title">Tur Sonucu</h1>
            <p class="ss-page-subtitle">Karşılaştırma detayı ve karar ekranı</p>
        </div>
        <SfButton CssClass="e-outline" @onclick="Geri">← Geri</SfButton>
    </div>


    <!-- Özet -->
    @if (_turSonucu != null)
    {
        var durumCls = _turSonucu.GenelDurum == "Onaylandi" ? "ss-badge-success" : "ss-badge-danger";
        <div class="ss-card" style="padding:16px 20px; margin-bottom:16px; display:flex; gap:32px; align-items:center; flex-wrap:wrap">
            <div>
                <span style="font-size:12px; color:var(--muted)">GENEL DURUM</span><br />
                <span class="ss-badge @durumCls" style="font-size:14px; margin-top:4px">
                    @(_turSonucu.GenelDurum == "Onaylandi" ? "✓ Onaylandı" : "⚠ Fark Var")
                </span>
            </div>
            <div>
                <span style="font-size:12px; color:var(--muted)">TOPLAM</span><br />
                <strong style="font-size:20px">@_turSonucu.ToplamMalzemeSayisi</strong>
            </div>
            <div>
                <span style="font-size:12px; color:var(--muted)">EŞLEŞTİ</span><br />
                <strong style="font-size:20px; color:var(--success)">@_turSonucu.EslesilenSayisi</strong>
            </div>
            <div>
                <span style="font-size:12px; color:var(--muted)">FARK VAR</span><br />
                <strong style="font-size:20px; color:var(--danger)">@_turSonucu.FarkliSayisi</strong>
            </div>
            <div>
                <span style="font-size:12px; color:var(--muted)">KARAR BEKLİYOR</span><br />
                <strong style="font-size:20px; color:var(--warn)">@_detaylar.Count(d => d.Durum == "FarkVar" && !d.OnaylananDeger.HasValue)</strong>
            </div>
            <div style="margin-left:auto; font-size:12px; color:var(--muted)">
                Hesaplandı: @_turSonucu.HesaplamaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>
    }

    <!-- Filtre -->
    <div class="ss-card" style="padding:12px 20px; margin-bottom:16px">
        <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap">
            <label style="font-size:12px; color:var(--muted); font-weight:600">FİLTRE:</label>
            <SfButton CssClass="@(_filtre == "Tumu" ? "e-primary e-small" : "e-outline e-small")" @onclick="@(() => _filtre = "Tumu")">Tümü</SfButton>
            <SfButton CssClass="@(_filtre == "FarkVar" ? "e-primary e-small" : "e-outline e-small")" @onclick="@(() => _filtre = "FarkVar")">Fark Var</SfButton>
            <SfButton CssClass="@(_filtre == "Eslesti" ? "e-primary e-small" : "e-outline e-small")" @onclick="@(() => _filtre = "Eslesti")">Eşleşti</SfButton>
            <SfButton CssClass="@(_filtre == "KararBekliyor" ? "e-primary e-small" : "e-outline e-small")" @onclick="@(() => _filtre = "KararBekliyor")">Karar Bekliyor</SfButton>
        </div>
    </div>

    <!-- Grid -->
    <div class="ss-card">
        <div style="display:flex; justify-content:flex-end; margin-bottom:12px">
            <SfButton CssClass="e-outline" IconCss="e-icons e-export-excel" @onclick="ExcelExport">
                Excel'e Aktar
            </SfButton>
        </div>
        <SfGrid @ref="_grid" DataSource="@FiltrelenmisDetaylar" AllowPaging="true" AllowSorting="true" AllowExcelExport="true">
            <GridPageSettings PageSize="20" />
            <GridEvents ExcelExportComplete="ExcelExportTamamlandi" TValue="TurSonucuDetayRow" />
            <GridColumns>
                <GridColumn Field="MalzemeKodu" HeaderText="Malzeme Kodu" Width="130" />
                <GridColumn Field="MalzemeAdi" HeaderText="Malzeme Adı" Width="200" />
                <GridColumn Field="LotNo" HeaderText="Lot No" Width="100" />
                <GridColumn Field="OlcuBirimi" HeaderText="Birim" Width="70" TextAlign="TextAlign.Center" />
                <GridColumn Field="Deger1" HeaderText="@_deger1Baslik" Width="110" Format="N2" TextAlign="TextAlign.Right" />
                <GridColumn Field="Deger2" HeaderText="@_deger2Baslik" Width="110" Format="N2" TextAlign="TextAlign.Right" />
                @if (_detaylar.Any(d => d.Deger3.HasValue))
                {
                    <GridColumn Field="Deger3" HeaderText="@_deger3Baslik" Width="110" Format="N2" TextAlign="TextAlign.Right" />
                }
                <GridColumn Field="Fark" HeaderText="Fark" Width="90" Format="N2" TextAlign="TextAlign.Right">
                    <Template>
                        @{
                            var d = (TurSonucuDetayRow)context;
                        }
                        <span style="color:@(d.Fark == 0 ? "var(--success)" : d.Fark > 0 ? "var(--warn)" : "var(--danger)"); font-weight:600">
                            @(d.Fark?.ToString("N2") ?? "—")
                        </span>
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="Durum" Width="120">
                    <Template>
                        @{
                            var d = (TurSonucuDetayRow)context;
                            var (cls, txt) = d.Durum switch
                            {
                                "Eslesti" => ("ss-badge-success", "Eşleşti"),
                                "FarkVar" => ("ss-badge-danger", "Fark Var"),
                                _ => ("ss-badge-muted", d.Durum)
                            };
                        }
                        <span class="ss-badge @cls">@txt</span>
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="Onaylanan" Width="110" TextAlign="TextAlign.Right">
                    <Template>
                        @{
                            var d = (TurSonucuDetayRow)context;
                        }
                        @if (d.OnaylananDeger.HasValue)
                        {
                            <span style="font-weight:600; color:var(--success)">@d.OnaylananDeger.Value.ToString("N2")</span>
                            @if (d.KararTipi == "Manuel")
                            {
                                <span class="ss-badge ss-badge-warn" style="margin-left:4px; font-size:10px">M</span>
                            }
                        }
                        else
                        {
                            <span style="color:var(--muted)">—</span>
                        }
                    </Template>
                </GridColumn>
                <GridColumn HeaderText="İşlem" Width="130" TextAlign="TextAlign.Center">
                    <Template>
                        @{
                            var d = (TurSonucuDetayRow)context;
                        }
                        @if (d.Durum == "FarkVar" && !d.OnaylananDeger.HasValue)
                        {
                            <SfButton CssClass="e-small e-outline" style="color:var(--warn)"
                                      @onclick="@(() => ManuelKararAc(d))">
                                ⚖️ Karar Ver
                            </SfButton>
                        }
                    </Template>
                </GridColumn>
            </GridColumns>
        </SfGrid>
    </div>
}

<!-- Manuel Karar Dialog -->
<SfDialog @bind-Visible="_manuelDialogAcik" Header="Manuel Karar" Width="420px" ShowCloseIcon="true">
    <DialogTemplates>
        <Content>
            @if (_aktifDetay != null)
            {
                <div class="ss-alert ss-alert-info" style="margin-bottom:16px">
                    <strong>@_aktifDetay.MalzemeKodu</strong> — @_aktifDetay.MalzemeAdi
                    @if (!string.IsNullOrEmpty(_aktifDetay.LotNo))
                    {
                        <span> | Lot: @_aktifDetay.LotNo</span>
                    }
                </div>
                <div style="display:flex; gap:16px; margin-bottom:16px">
                    <div style="flex:1; text-align:center; padding:12px; background:var(--bg); border-radius:8px">
                        <div style="font-size:11px; color:var(--muted)">@_deger1Baslik</div>
                        <div style="font-size:20px; font-weight:700">@(_aktifDetay.Deger1?.ToString("N2") ?? "—")</div>
                    </div>
                    <div style="flex:1; text-align:center; padding:12px; background:var(--bg); border-radius:8px">
                        <div style="font-size:11px; color:var(--muted)">@_deger2Baslik</div>
                        <div style="font-size:20px; font-weight:700">@(_aktifDetay.Deger2?.ToString("N2") ?? "—")</div>
                    </div>
                    @if (_aktifDetay.Deger3.HasValue)
                    {
                        <div style="flex:1; text-align:center; padding:12px; background:var(--bg); border-radius:8px">
                            <div style="font-size:11px; color:var(--muted)">@_deger3Baslik</div>
                            <div style="font-size:20px; font-weight:700">@_aktifDetay.Deger3.Value.ToString("N2")</div>
                        </div>
                    }
                </div>
                <div class="ss-form-group">
                    <label>Onaylanan Değer *</label>
                    <SfNumericTextBox @bind-Value="_kararDeger" Format="N2" />
                </div>
                <div class="ss-form-group">
                    <label>Gerekçe *</label>
                    <SfTextBox @bind-Value="_kararGerekce" Multiline="true" Placeholder="Kararınızın gerekçesini yazın..." />
                </div>
            }
        </Content>
        <FooterTemplate>
            <SfButton CssClass="e-outline" @onclick="@(() => _manuelDialogAcik = false)">İptal</SfButton>
            <SfButton CssClass="e-primary" Disabled="@_kararYukleniyor" @onclick="ManuelKararKaydet">
                @(_kararYukleniyor ? "Kaydediliyor..." : "✓ Kaydet")
            </SfButton>
        </FooterTemplate>
    </DialogTemplates>
</SfDialog>

@code {
    [Parameter] public int TurId { get; set; }

    private SfGrid<TurSonucuDetayRow> _grid = null!;
    private bool _yukleniyor = true;
    private TurSonucuDto? _turSonucu;
    private string _deger1Baslik = "Ekip 1";
    private string _deger2Baslik = "Ekip 2";
    private string _deger3Baslik = "Kontrol";
    private List<TurSonucuDetayRow> _detaylar = [];
    private string _filtre = "Tumu";
    private string _mesaj = "";
    private bool _hata = false;

    // Manuel karar
    private bool _manuelDialogAcik = false;
    private TurSonucuDetayRow? _aktifDetay;
    private decimal _kararDeger = 0;
    private string _kararGerekce = "";
    private bool _kararYukleniyor = false;

    record TurSonucuDetayRow(int Id, string MalzemeKodu, string MalzemeAdi, string? LotNo, string? SeriNo,
        string OlcuBirimi, decimal? Deger1, decimal? Deger2, decimal? Deger3, decimal? Fark, decimal? FarkYuzdesi,
        string Durum, decimal? OnaylananDeger, string? KararTipi);

    private IEnumerable<TurSonucuDetayRow> FiltrelenmisDetaylar => _filtre switch
    {
        "FarkVar" => _detaylar.Where(d => d.Durum == "FarkVar"),
        "Eslesti" => _detaylar.Where(d => d.Durum == "Eslesti"),
        "KararBekliyor" => _detaylar.Where(d => d.Durum == "FarkVar" && !d.OnaylananDeger.HasValue),
        _ => _detaylar
    };

    private async Task Geri() => await JS.InvokeVoidAsync("history.back");

    protected override async Task OnInitializedAsync()
    {
        _yukleniyor = true;
        try
        {
            var sonuc = await OturumuService.GetTurSonucuAsync(TurId);
            if (sonuc != null)
            {
                _turSonucu = sonuc;
                // Tur tipine göre kolon başlıkları
                if (sonuc.TurTipi == "ErpKarsilastirma")
                {
                    _deger1Baslik = "Fiili Sayım";
                    _deger2Baslik = "ERP";
                }
                else
                {
                    _deger1Baslik = "Birinci Ekip";
                    _deger2Baslik = "İkinci Ekip";
                    _deger3Baslik = "Kontrol Ekibi";
                }
                _detaylar = sonuc.Detaylar.Select(d => new TurSonucuDetayRow(
                    d.Id, d.MalzemeKodu, d.MalzemeAdi, d.LotNo, d.SeriNo,
                    d.OlcuBirimi, d.Deger1, d.Deger2, d.Deger3, d.Fark, d.FarkYuzdesi,
                    d.Durum, d.OnaylananDeger, d.KararTipi
                )).ToList();
            }
            else
            {
                _mesaj = "Karşılaştırma henüz hesaplanmamış.";
                _hata = true;
            }
        }
        catch (Exception ex) { Toast.Hata(ex.Message); }
        finally { _yukleniyor = false; }
    }

    private void ManuelKararAc(TurSonucuDetayRow detay)
    {
        _aktifDetay = detay;
        _kararDeger = detay.Deger1 ?? detay.Deger2 ?? 0;
        _kararGerekce = "";
        _manuelDialogAcik = true;
    }

    private async Task ManuelKararKaydet()
    {
        if (_aktifDetay == null) return;
        if (string.IsNullOrWhiteSpace(_kararGerekce)) { Toast.Hata("Gerekçe zorunludur."); return; }

        _kararYukleniyor = true;
        try
        {
            var dto = new ManuelKararDto(_kararDeger, _kararGerekce);
            await OturumuService.ManuelKararVerAsync(_aktifDetay.Id, dto);
            _manuelDialogAcik = false;
            Toast.Basari("Karar kaydedildi.");
            await OnInitializedAsync();
        }
        catch (Exception ex) { Toast.Hata(ex.Message); }
        finally { _kararYukleniyor = false; }
    }

    private async Task ExcelExport()
    {
        var exportProps = new ExcelExportProperties
        {
            FileName = $"KarsilastirmaRaporu_Tur{_turSonucu?.TurNo}_{DateTime.Now:yyyyMMdd_HHmm}.xlsx",
            ExportType = Syncfusion.Blazor.Grids.ExportType.AllPages
        };
        await _grid.ExportToExcelAsync(exportProps);
    }

    private void ExcelExportTamamlandi(object args) { }
}
