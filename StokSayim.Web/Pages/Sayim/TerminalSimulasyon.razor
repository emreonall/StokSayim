@page "/simulasyon/terminal"
@attribute [Authorize(Roles = "Admin,SayimSorumlusu,SayimEkibi")]
@inject IAuthHttpService AuthService
@inject ISayimOturumuHttpService OturumuService
@inject ISayimKaydiHttpService KaydiService
@inject MalzemeHttpService MalzemeService
@inject NavigationManager Nav

<PageTitle>El Terminali Simülasyonu</PageTitle>

<div class="ss-page-header">
    <div>
        <h1 class="ss-page-title">🔧 El Terminali Simülasyonu</h1>
        <p class="ss-page-subtitle">Gerçek API üzerinde ekip sayım akışını simüle eder</p>
    </div>
    <SfButton CssClass="e-outline" @onclick="@(() => Nav.NavigateTo("/"))">← Geri</SfButton>
</div>

@if (!string.IsNullOrEmpty(_hata))
{
    <div class="ss-alert ss-alert-danger">@_hata</div>
}
@if (!string.IsNullOrEmpty(_basari))
{
    <div class="ss-alert ss-alert-success">@_basari</div>
}

<!-- Adım göstergesi -->
<div style="display:flex; gap:0; margin-bottom:24px; border-radius:8px; overflow:hidden; border:1px solid var(--border)">
    @foreach (var (label, idx) in new[] { ("1. Giriş", 0), ("2. Görev", 1), ("3. Kayıt Aç", 2), ("4. Sayım", 3), ("5. Tamamla", 4), ("6. Karşılaştır", 5) })
    {
        var aktif = _adim == idx;
        var tamamlandi = _adim > idx;
        <div style="flex:1; padding:10px 6px; text-align:center; font-size:12px; font-weight:600;
            background:@(aktif ? "var(--primary)" : tamamlandi ? "var(--success)" : "var(--bg)");
            color:@(aktif || tamamlandi ? "#fff" : "var(--muted)");
            border-right: 1px solid var(--border)">
            @(tamamlandi ? "✓ " : "")@label
        </div>
    }
</div>

<!-- ADIM 1: GİRİŞ -->
@if (_adim == 0)
{
    <div class="ss-card" style="max-width:480px; margin:0 auto">
        <div class="ss-card-title">🔐 Ekip Kullanıcısı Girişi</div>
        <p style="font-size:13px; color:var(--muted); margin-bottom:16px">
            SayimEkibi rolündeki kullanıcı bilgilerini girin.
        </p>
        <div class="ss-form-group">
            <label>E-posta</label>
            <SfTextBox @bind-Value="_email" Placeholder="ekip@firma.com" />
        </div>
        <div class="ss-form-group">
            <label>Şifre</label>
            <SfTextBox @bind-Value="_sifre" Type="InputType.Password" Placeholder="••••••" />
        </div>
        <SfButton CssClass="e-primary" Disabled="@_yukleniyor" @onclick="Login" style="width:100%">
            @(_yukleniyor ? "Giriş yapılıyor..." : "Giriş Yap →")
        </SfButton>
    </div>
}

<!-- ADIM 2: BÖLGE SEÇİMİ -->
@if (_adim == 1)
{
    <div class="ss-card" style="max-width:640px; margin:0 auto">
        <div class="ss-card-title">📍 Sayım Yapılacak Bölgeyi Seçin</div>
        @if (_gorevler == null || !_gorevler.Secenekler.Any())
        {
            <div class="ss-alert ss-alert-warn">Aktif sayım görevi bulunamadı.</div>
            <p style="font-size:13px; color:var(--muted); margin-bottom:12px">
                Ekibinizin aktif bir sayım turuna atanmış olması gerekir.
            </p>
            <SfButton CssClass="e-outline" @onclick="@(() => _adim = 0)">← Geri Dön</SfButton>
        }
        else
        {
            <p style="font-size:13px; color:var(--muted); margin-bottom:16px">
                <strong>@_gorevler.AdSoyad</strong> — @_gorevler.Secenekler.Count aktif görev bulundu.
            </p>
            <div style="display:flex; flex-direction:column; gap:10px">
                @foreach (var s in _gorevler.Secenekler)
                {
                    var tamamlandi = s.SayimTamamlandi;
                    var devamEdiyor = s.SayimKaydiId.HasValue && !tamamlandi;
                    <div style="border:2px solid @(tamamlandi ? "var(--border)" : devamEdiyor ? "var(--warning, #f59e0b)" : "var(--primary)");
                        border-radius:8px; padding:14px; cursor:@(tamamlandi ? "default" : "pointer");
                        opacity:@(tamamlandi ? "0.6" : "1"); background:var(--surface)"
                         @onclick="@(tamamlandi? async() => await Task.CompletedTask : async () => await GorevSec(s))">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start">
                            <div>
                                <div style="font-weight:700; font-size:15px">@s.BolgeAdi</div>
                                <div style="font-size:12px; color:var(--muted)">@s.BolgeKodu</div>
                            </div>
                            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px">
                                <span class="ss-badge @(tamamlandi ? "ss-badge-success" : devamEdiyor ? "ss-badge-warn" : "ss-badge-primary")">
                                    @(tamamlandi ? "✓ Tamamlandı" : devamEdiyor ? "▶ Devam Ediyor" : "Başlamadı")
                                </span>
                                <span class="ss-badge ss-badge-accent">@s.EkipRolu.Ad</span>
                            </div>
                        </div>
                        <div style="display:flex; gap:16px; margin-top:10px; font-size:12px; color:var(--muted)">
                            <span>🏢 @s.EkipAdi</span>
                            <span>📋 Tur @s.TurNo — @s.TurTipi</span>
                            @if (devamEdiyor)
                            {
                                <span style="color:var(--warning, #f59e0b)">⚡ Kaldığınız yerden devam</span>
                            }
                        </div>
                    </div>
                }
            </div>
            <div style="margin-top:16px">
                <SfButton CssClass="e-outline" @onclick="@(() => _adim = 0)">← Geri Dön</SfButton>
            </div>
        }
    </div>
}

<!-- ADIM 3: KAYIT AÇ -->
@if (_adim == 2)
{
    <div class="ss-card" style="max-width:560px; margin:0 auto">
        <div class="ss-card-title">📋 Sayım Kaydı Aç</div>
        <p style="font-size:13px; color:var(--muted); margin-bottom:16px">
            Tur <strong>@_seciliGorev?.TurNo</strong> için <strong>@_seciliGorev?.EkipAdi</strong> ekibinin sayım kaydı açılacak.
        </p>
        <table style="width:100%; border-collapse:collapse; margin-bottom:20px">
            <tr><td style="padding:6px 0; color:var(--muted); width:120px">Tur ID</td><td style="font-weight:600">@_seciliGorev?.SayimTuruId</td></tr>
            <tr><td style="padding:6px 0; color:var(--muted)">Ekip ID</td><td style="font-weight:600">@_seciliGorev?.EkipId</td></tr>
            <tr><td style="padding:6px 0; color:var(--muted)">Bölge</td><td style="font-weight:600">@_seciliGorev?.BolgeAdi</td></tr>
        </table>
        <div style="display:flex; gap:8px">
            <SfButton CssClass="e-outline" @onclick="@(() => _adim = 1)">← Geri</SfButton>
            <SfButton CssClass="e-primary" Disabled="@_yukleniyor" @onclick="KaydiAc">
                @(_yukleniyor ? "Açılıyor..." : "▶ Kaydı Aç →")
            </SfButton>
        </div>
    </div>
}

<!-- ADIM 4: SAYIM -->
@if (_adim == 3)
{
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px">
        <!-- Sol: Malzeme Ekle -->
        <div class="ss-card">
            <div class="ss-card-title">📦 Malzeme Ekle</div>
            <p style="font-size:12px; color:var(--muted); margin-bottom:12px">
                Kayıt ID: <strong>@_kaydi?.Id</strong> · @_kaydi?.EkipAdi (@_kaydi?.EkipRolu)
            </p>
            <div class="ss-form-group">
                <label>Malzeme Kodu *</label>
                <input type="text" class="e-input" placeholder="Örn: MAL001"
                       value="@_malzemeKodu"
                       @oninput="@(e => _malzemeKodu = e.Value?.ToString() ?? "")"
                       @onblur="MalzemeKoduBlur" />
            </div>
            @if (_malzemeBulunamadi)
            {
                <div style="color:var(--danger); font-size:12px; margin-bottom:8px">⚠️ Malzeme bulunamadı. Lütfen kodu kontrol edin.</div>
            }
            <div class="ss-form-group">
                <label>Malzeme Adı</label>
                <SfTextBox Value="@_malzemeAdi" Enabled="false" Placeholder="Kod girilince otomatik dolar" />
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px">
                <div class="ss-form-group">
                    <label>Miktar *</label>
                    <SfNumericTextBox @bind-Value="_miktar" Min="0" Decimals="2" />
                </div>
                <div class="ss-form-group">
                    <label>Ölçü Birimi</label>
                    <SfTextBox Value="@_birim" Enabled="false" Placeholder="Otomatik" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px">
                <div class="ss-form-group">
                    <label>Lot No</label>
                    <SfTextBox @bind-Value="_lotNo" Placeholder="İsteğe bağlı" />
                </div>
                <div class="ss-form-group">
                    <label>Seri No</label>
                    <SfTextBox @bind-Value="_seriNo" Placeholder="İsteğe bağlı" />
                </div>
            </div>
            <div style="display:flex; gap:8px">
                <SfButton CssClass="e-primary" @onclick="MalzemeEkle" style="flex:1">
                    ➕ Ekle
                </SfButton>
                <SfButton CssClass="e-outline" @onclick="FormTemizle">Temizle</SfButton>
            </div>
        </div>

        <!-- Sağ: Listeler -->
        <div style="display:flex; flex-direction:column; gap:12px">

            <!-- Cihaz listesi (henüz gönderilmemiş) -->
            <div class="ss-card" style="border:2px solid @(_cihazListesi.Any() ? "var(--warning, #f59e0b)" : "var(--border)")">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px">
                    <div style="font-weight:600; font-size:14px">
                        📱 Cihaz Listesi
                        <span class="ss-badge @(_cihazListesi.Any() ? "ss-badge-warn" : "ss-badge-muted")" style="margin-left:8px">
                            @_cihazListesi.Count
                        </span>
                    </div>
                    @if (_cihazListesi.Any())
                    {
                        <SfButton CssClass="e-primary e-small" Disabled="@_yukleniyor" @onclick="TopluGonder">
                            @(_yukleniyor ? "Gönderiliyor..." : "⬆ Sisteme Aktar")
                        </SfButton>
                    }
                </div>
                @if (!_cihazListesi.Any())
                {
                    <div style="font-size:12px; color:var(--muted); text-align:center; padding:8px">
                        Eklenen malzemeler burada birikir
                    </div>
                }
                else
                {
                    <div style="overflow-y:auto; max-height:180px">
                        <table style="width:100%; border-collapse:collapse; font-size:12px">
                            <tbody>
                                @foreach (var d in _cihazListesi)
                                {
                                    <tr style="border-top:1px solid var(--border)">
                                        <td style="padding:5px 6px; font-weight:600">@d.MalzemeKodu</td>
                                        <td style="padding:5px 6px; color:var(--muted)">@d.MalzemeAdi</td>
                                        <td style="padding:5px 6px; text-align:right; font-weight:600">@d.SayilanMiktar @d.OlcuBirimi</td>
                                        <td style="padding:5px 6px; text-align:center">
                                            <span style="cursor:pointer; color:var(--danger)"
                                                  @onclick="@(() => _cihazListesi.Remove(d))">✕</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- DB'deki onaylı kayıtlar -->
            <div class="ss-card">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px">
                    <div style="font-weight:600; font-size:14px">
                        🗄 Sistemdeki Kayıtlar
                        <span class="ss-badge ss-badge-primary" style="margin-left:8px">@(_kaydi?.Detaylar.Count() ?? 0)</span>
                    </div>
                    <SfButton CssClass="e-outline e-small" @onclick="KaydiYenile">🔄</SfButton>
                </div>
                @if (_kaydi == null || !_kaydi.Detaylar.Any())
                {
                    <div style="font-size:12px; color:var(--muted); text-align:center; padding:8px">
                        Henüz sisteme aktarılmış kayıt yok
                    </div>
                }
                else
                {
                    <div style="overflow-y:auto; max-height:200px">
                        <table style="width:100%; border-collapse:collapse; font-size:12px">
                            <tbody>
                                @foreach (var d in _kaydi.Detaylar)
                                {
                                    <tr style="border-top:1px solid var(--border)">
                                        <td style="padding:5px 6px; font-weight:600">@d.MalzemeKodu</td>
                                        <td style="padding:5px 6px; color:var(--muted)">@d.MalzemeAdi</td>
                                        <td style="padding:5px 6px; text-align:right; font-weight:600">@d.SayilanMiktar @d.OlcuBirimi</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div style="margin-top:12px; border-top:1px solid var(--border); padding-top:10px">
                    <SfButton CssClass="e-danger" Disabled="@(_kaydi == null || _yukleniyor)"
                              @onclick="@(() => _adim = 4)" style="width:100%">
                        ✅ Sayımı Tamamla →
                    </SfButton>
                </div>
            </div>
        </div>
    </div>
}

<!-- ADIM 5: TAMAMLA -->
@if (_adim == 4)
{
    <div class="ss-card" style="max-width:560px; margin:0 auto">
        <div class="ss-card-title">✅ Sayımı Tamamla</div>
        <p style="font-size:13px; color:var(--muted); margin-bottom:16px">
            Toplam <strong>@(_kaydi?.Detaylar.Count() ?? 0) malzeme</strong> kaydedildi. Tamamladıktan sonra değişiklik yapılamaz.
        </p>
        <table style="width:100%; border-collapse:collapse; margin-bottom:20px">
            @foreach (var d in _kaydi?.Detaylar ?? [])
            {
                <tr style="border-bottom:1px solid var(--border)">
                    <td style="padding:6px 0; font-weight:600">@d.MalzemeKodu</td>
                    <td style="padding:6px 0">@d.MalzemeAdi</td>
                    <td style="padding:6px 0; text-align:right; font-weight:600">@d.SayilanMiktar @d.OlcuBirimi</td>
                </tr>
            }
        </table>
        <div style="display:flex; gap:8px">
            <SfButton CssClass="e-outline" @onclick="@(() => _adim = 3)">← Geri Dön</SfButton>
            <SfButton CssClass="e-primary" Disabled="@_yukleniyor" @onclick="Tamamla">
                @(_yukleniyor ? "Tamamlanıyor..." : "✅ Evet, Tamamla")
            </SfButton>
        </div>
    </div>
}

<!-- ADIM 6: KARŞILAŞTIRMA -->
@if (_adim == 5)
{
    <div class="ss-card" style="max-width:560px; margin:0 auto; text-align:center; margin-bottom:24px">
        <div style="font-size:48px; margin-bottom:12px">🎉</div>
        <div class="ss-card-title">Sayım Tamamlandı!</div>
        <p style="color:var(--muted); font-size:14px">
            <strong>@_kaydi?.EkipAdi</strong> ekibinin sayımı başarıyla kaydedildi.
        </p>
        <p style="font-size:13px; color:var(--muted); margin-top:8px">
            Tüm ekipler tamamladıktan sonra yönetici karşılaştırma başlatabilir.
        </p>
    </div>

    @if (_seciliGorev?.SayimTuruId != null)
    {
        <div class="ss-card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px">
                <div class="ss-card-title" style="margin-bottom:0">⚖️ Karşılaştırma Başlat</div>
                <span style="font-size:12px; color:var(--muted)">Admin/SayimSorumlusu yetkisi gerekir</span>
            </div>
            <p style="font-size:13px; color:var(--muted); margin-bottom:16px">
                Tüm ekipler sayımını tamamladıysa karşılaştırma hesaplanabilir. Tüm katılımcılar tamamlamadan hata verir.
            </p>
            <SfButton CssClass="e-primary" Disabled="@_yukleniyor" @onclick="Karsilastir">
                @(_yukleniyor ? "Hesaplanıyor..." : "⚖️ Karşılaştırmayı Hesapla")
            </SfButton>
        </div>
    }

    @if (_turSonucu != null)
    {
        <div class="ss-card">
            <div class="ss-card-title">📊 Karşılaştırma Sonucu</div>
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px">
                <div style="text-align:center; padding:16px; background:var(--bg); border-radius:8px">
                    <div style="font-size:28px; font-weight:700">@_turSonucu.ToplamMalzeme</div>
                    <div style="font-size:12px; color:var(--muted)">Toplam</div>
                </div>
                <div style="text-align:center; padding:16px; background:#f0fdf4; border-radius:8px">
                    <div style="font-size:28px; font-weight:700; color:var(--success)">@_turSonucu.Eslesen</div>
                    <div style="font-size:12px; color:var(--muted)">Eşleşti</div>
                </div>
                <div style="text-align:center; padding:16px; background:#fff5f5; border-radius:8px">
                    <div style="font-size:28px; font-weight:700; color:var(--danger)">@_turSonucu.Farkli</div>
                    <div style="font-size:12px; color:var(--muted)">Farklı</div>
                </div>
            </div>
            <div style="text-align:center">
                <span class="ss-badge @(_turSonucu.Farkli == 0 ? "ss-badge-success" : "ss-badge-danger")" style="font-size:14px; padding:8px 16px">
                    @(_turSonucu.Farkli == 0 ? "✓ Tüm malzemeler eşleşti" : $"⚠ {_turSonucu.Farkli} malzemede fark var")
                </span>
            </div>
        </div>
    }

    <div style="display:flex; gap:8px; justify-content:center; margin-top:16px">
        <SfButton CssClass="e-outline" @onclick="YeniSimulasyon">🔄 Yeni Simülasyon Başlat</SfButton>
        <SfButton CssClass="e-outline" @onclick="@(() => Nav.NavigateTo($"/bolgeler/{_seciliGorev?.BolgeId}"))">
            📍 Bölge Detayına Git
        </SfButton>
    </div>
}

@code {
    private int _adim = 0;
    private bool _yukleniyor = false;
    private string _hata = "";
    private string _basari = "";

    // Giriş
    private string _email = "";
    private string _sifre = "";

    // Görev
    private AktifGorevlerDto? _gorevler;
    private GorevSecenekDto? _seciliGorev;

    // Kayıt
    private SayimKaydiDto? _kaydi;

    // Cihaz üzerindeki geçici liste (henüz API'ye gönderilmemiş)
    private record CihazSatir(string MalzemeKodu, string MalzemeAdi, string OlcuBirimi,
        string? LotNo, string? SeriNo, decimal SayilanMiktar, string? Notlar);
    private List<CihazSatir> _cihazListesi = new();

    // Malzeme form
    private string _malzemeKodu = "";
    private string _malzemeAdi = "";
    private bool _malzemeBulunamadi = false;
    private decimal _miktar = 0;
    private string _birim = "";
    private string? _lotNo;
    private string? _seriNo;

    // Sonuç
    private TurSonucuOzetDto? _turSonucu;

    private void MesajTemizle() { _hata = ""; _basari = ""; }

    // ADIM 1: Login
    private async Task Login()
    {
        MesajTemizle();
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_sifre))
        {
            _hata = "E-posta ve şifre zorunludur."; return;
        }
        _yukleniyor = true;
        try
        {
            var result = await AuthService.LoginAsync(new LoginRequestDto(_email, _sifre));
            if (result == null) { _hata = "Giriş başarısız. Bilgileri kontrol edin."; return; }

            _gorevler = await AuthService.GetAktifGorevlerAsync();
            _basari = $"Giriş başarılı. Hoş geldiniz, {result.AdSoyad}!";
            if (_gorevler?.Secenekler.Count == 0)
            {
                _hata = "Aktif sayım görevi bulunamadı.";
                _adim = 1;
            }
            else if (_gorevler?.Secenekler.Count == 1)
            {
                // Tek bölge varsa doğrudan seç
                await GorevSec(_gorevler.Secenekler[0]);
            }
            else
            {
                // Birden fazla bölge — seçim ekranı
                _adim = 1;
            }
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    // Bölge seçimi — mevcut kayıt varsa yükle, yoksa adım 3'e geç
    private async Task GorevSec(GorevSecenekDto secenek)
    {
        MesajTemizle();
        _seciliGorev = secenek;
        _yukleniyor = true;
        try
        {
            if (secenek.SayimKaydiId.HasValue)
            {
                _kaydi = await KaydiService.GetByIdAsync(secenek.SayimKaydiId.Value);
                if (_kaydi?.DurumAdi == "Tamamlandi")
                {
                    _hata = "Bu bölgedeki sayımınız zaten tamamlanmış.";
                    _seciliGorev = null;
                    _adim = 1;
                    return;
                }
                _basari = $"{secenek.BolgeAdi} — kaldığınız yerden devam ediyorsunuz.";
                _adim = 3;
            }
            else
            {
                _adim = 2; // Kayıt aç adımına geç
            }
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    // ADIM 3: Kayıt aç
    private async Task KaydiAc()
    {
        if (_seciliGorev?.SayimTuruId == null || _seciliGorev?.EkipId == null)
        {
            _hata = "Tur veya ekip bilgisi eksik."; return;
        }
        MesajTemizle();
        _yukleniyor = true;
        try
        {
            _kaydi = await KaydiService.AcAsync(_seciliGorev.SayimTuruId, _seciliGorev.EkipId);
            if (_kaydi == null) { _hata = "Kayıt açılamadı."; return; }
            _basari = $"Sayım kaydı açıldı. (ID: {_kaydi.Id})";
            _adim = 3;
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    // Malzeme kodu blur — API'den malzeme adı ve birimini getir
    private async void MalzemeKoduBlur()
    {
        _malzemeAdi = "";
        _birim = "";
        _malzemeBulunamadi = false;

        if (string.IsNullOrWhiteSpace(_malzemeKodu)) return;

        var malzeme = await MalzemeService.GetByKodAsync(_malzemeKodu.Trim().ToUpper());
        if (malzeme != null)
        {
            _malzemeAdi = malzeme.MalzemeAdi;
            _birim = malzeme.OlcuBirimi;
        }
        else
        {
            _malzemeBulunamadi = true;
        }
        StateHasChanged();
    }

    // ADIM 4: Malzeme ekle — cihaz listesine ekle (API'ye henüz gönderme)
    private void MalzemeEkle()
    {
        if (string.IsNullOrWhiteSpace(_malzemeKodu) || _malzemeBulunamadi)
        {
            _hata = "Malzeme kodu ve adı zorunludur."; return;
        }
        if (_miktar <= 0) { _hata = "Miktar 0'dan büyük olmalıdır."; return; }

        MesajTemizle();
        _cihazListesi.Add(new CihazSatir(
            MalzemeKodu: _malzemeKodu.Trim().ToUpper(),
            MalzemeAdi: _malzemeAdi,
            OlcuBirimi: _birim,
            LotNo: string.IsNullOrWhiteSpace(_lotNo) ? null : _lotNo.Trim(),
            SeriNo: string.IsNullOrWhiteSpace(_seriNo) ? null : _seriNo.Trim(),
            SayilanMiktar: _miktar,
            Notlar: null
        ));
        _basari = $"{_malzemeKodu.Trim().ToUpper()} cihaz listesine eklendi. ({_cihazListesi.Count} satır bekliyor)";
        FormTemizle();
    }

    // Cihaz listesini API'ye toplu gönder
    private async Task TopluGonder()
    {
        if (_kaydi == null || !_cihazListesi.Any()) return;
        MesajTemizle();
        _yukleniyor = true;
        try
        {
            var dtolar = _cihazListesi.Select(c => new SayimKaydiDetayEkleDto(
                c.MalzemeKodu, c.LotNo, c.SeriNo, c.SayilanMiktar, c.Notlar));
            var sonuc = await KaydiService.TopluDetayEkleAsync(_kaydi.Id, dtolar);
            if (sonuc != null)
            {
                // Başarılı — cihaz listesini temizle, DB listesini güncelle
                _cihazListesi.Clear();
                await KaydiYenile();
                _basari = $"✅ {sonuc.EklenenSatir} satır sisteme aktarıldı.";
                if (sonuc.HataliSatir > 0)
                    _hata = $"{sonuc.HataliSatir} satırda hata: " + string.Join(" | ", sonuc.Hatalar);
            }
        }
        catch (Exception ex)
        {
            // Başarısız — cihaz listesi KORUNUR, kullanıcı tekrar deneyebilir
            _hata = $"Aktarım başarısız — cihaz listesi korundu. Hata: {ex.Message}";
        }
        finally { _yukleniyor = false; }
    }

    private async Task DetaySil(int detayId)
    {
        MesajTemizle();
        _yukleniyor = true;
        try
        {
            await KaydiService.DetaySilAsync(detayId);
            await KaydiYenile();
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    private async Task KaydiYenile()
    {
        if (_kaydi == null) return;
        _kaydi = await KaydiService.GetByIdAsync(_kaydi.Id);
    }

    private void FormTemizle()
    {
        _malzemeKodu = ""; _malzemeAdi = ""; _birim = ""; _malzemeBulunamadi = false; _miktar = 0;
        _birim = "ADET"; _lotNo = null; _seriNo = null;
    }

    // ADIM 5: Tamamla
    private async Task Tamamla()
    {
        if (_kaydi == null) return;
        MesajTemizle();
        _yukleniyor = true;
        try
        {
            await KaydiService.TamamlaAsync(_kaydi.Id);
            _basari = "Sayım başarıyla tamamlandı!";
            _adim = 5;
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    // ADIM 6: Karşılaştır
    private async Task Karsilastir()
    {
        if (_seciliGorev?.SayimTuruId == null) return;
        MesajTemizle();
        _yukleniyor = true;
        try
        {
            await OturumuService.HesaplaKarsilastirmaAsync(_seciliGorev.SayimTuruId);
            // Sonucu almak için oturumu çek
            if (_seciliGorev.BolgeId != 0)
            {
                var oturum = await OturumuService.GetByBolgeAsync(_seciliGorev.BolgeId);
                var tur = oturum?.Turler.FirstOrDefault(t => t.Id == _seciliGorev.SayimTuruId);
                _turSonucu = tur?.Sonuc;
            }
            _basari = "Karşılaştırma tamamlandı.";
        }
        catch (Exception ex) { _hata = ex.Message; }
        finally { _yukleniyor = false; }
    }

    private void YeniSimulasyon()
    {
        _adim = 0; _email = ""; _sifre = "";
        _gorevler = null; _seciliGorev = null;
        _kaydi = null; _turSonucu = null;
        _cihazListesi.Clear();
        MesajTemizle(); FormTemizle();
    }
}
